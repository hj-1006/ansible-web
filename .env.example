# 서버 시크릿 (선택)
ANSIBLE_WEB_SECRET_KEY=your-secret-key

# 최초 부트스트랩 API 키 (선택, 없으면 자동 생성)
ANSIBLE_WEB_BOOTSTRAP_API_KEY=aw_your_custom_key_here

# --- MySQL (권장, 원격 DB 서버 가능) ---
ANSIBLE_WEB_DB_HOST=192.168.1.100
ANSIBLE_WEB_DB_PORT=3306
ANSIBLE_WEB_DB_USER=ansible_web
ANSIBLE_WEB_DB_PASSWORD=your-mysql-password
ANSIBLE_WEB_DB_NAME=ansible_web

# 전체 URL 한 줄 지정 시 위 설정보다 우선
# ANSIBLE_WEB_DATABASE_URL=mysql+pymysql://user:pass@db-host:3306/ansible_web?charset=utf8mb4

# DB_USER 비우면 SQLite (data/ansible_web.db)

# SNMP / 모니터링
# ANSIBLE_WEB_SNMP_TIMEOUT=10
# ANSIBLE_WEB_SNMP_POLL_INTERVAL_DEFAULT=30
# ANSIBLE_WEB_METRICS_RETENTION_DAYS=7
